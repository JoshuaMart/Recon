# Database
DATABASE_URL=postgres://recon:recon@localhost:5432/recon?sslmode=disable

# Auth
JWT_SECRET=change-me-to-a-random-32-char-string
PASSWORD_HASH='$2a$12$xxxx'  # generate with: go run . hash-password
INGEST_API_KEY=change-me-ingest-key

# Fingerprinter
FINGERPRINTER_URL=http://localhost:3001

# Scaleway
SCALEWAY_ACCESS_KEY=scw-access-key
SCALEWAY_SECRET_KEY=scw-secret-key
SCALEWAY_PROJECT_ID=scw-project-id
SCALEWAY_REGION=fr-par
SCALEWAY_JOB_DEFINITION_ID=your-job-definition-uuid

# Server
PORT=3002
API_BASE_URL=https://your-api-domain.com
CORS_ORIGINS=http://localhost:3000
JWT_EXPIRY=24h
FINGERPRINT_WORKERS=3

# Scheduler
RECON_CRON=0 0 1,15 * *
REVALIDATION_CRON=0 0 8,23 * *

# Notifications (optional)
# DISCORD_WEBHOOK_URL=
# NOTIFICATION_CALLBACK_URL=
# NOTIFICATION_CALLBACK_SECRET=
